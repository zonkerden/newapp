# Copy this to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard).
#
# The anon key is safe to expose in client-side code — it's designed for
# that — but it only works because Row Level Security policies (see
# supabase/schema.sql) restrict every table to auth.uid() = user_id.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
